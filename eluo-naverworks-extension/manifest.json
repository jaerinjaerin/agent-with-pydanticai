{
  "manifest_version": 3,
  "name": "Eluo NaverWorks 비용처리",
  "version": "1.0.0",
  "description": "Ask Eluo 챗봇에서 분석한 영수증 데이터를 NaverWorks에 자동 입력",
  "permissions": ["activeTab", "storage"],
  "content_scripts": [
    {
      "matches": ["http://localhost:8501/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.worksmobile.com/*"],
      "js": ["naverworks_filler.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
